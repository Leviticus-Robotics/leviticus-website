---
import BandSection from "../components/ui/BandSection.astro";
import Card from "../components/ui/Card.astro";
import DisplayHeading from "../components/ui/DisplayHeading.astro";
import Eyebrow from "../components/ui/Eyebrow.astro";
import Grid from "../components/ui/Grid.astro";
import HeroSection from "../components/ui/HeroSection.astro";
import Lead from "../components/ui/Lead.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
	title="Mission Statement"
	description="Read FTC team 36099 Leviticus's mission statement and goals as a rookie team."
>
	<HeroSection aria-labelledby="mission-title">
		<div>
			<Eyebrow>Mission Statement</Eyebrow>
			<DisplayHeading id="mission-title">Rookie team, real purpose.</DisplayHeading>
			<Lead>
				As a first-year rookie team, Leviticus aims to promote interest in STEM
				through FTC competition, community outreach, and a shared love of robots.
			</Lead>
		</div>
		<Card class="bg-linear-to-br from-brand-purple to-brand-blue text-white">
			<Eyebrow class="text-white/80">Our mission</Eyebrow>
			<SectionHeading class="text-white" size="card">Serve and build.</SectionHeading>
			<p class="text-xl leading-[1.45] text-white/90">
				Our team unites six passionate high school students under a single mission:
				to serve the community and build the best robot.
			</p>
		</Card>
	</HeroSection>

	<BandSection aria-labelledby="why-title">
		<Grid>
			<Card>
				<Eyebrow>STEM outreach</Eyebrow>
				<SectionHeading id="why-title" size="card">Share the work.</SectionHeading>
				<p>
					We aim to promote interest in STEM throughout the local community by
					competing in the FIRST Tech Challenge and sharing our love of robots.
				</p>
			</Card>
			<Card>
				<Eyebrow>Team culture</Eyebrow>
				<SectionHeading size="card">Gracious professionalism.</SectionHeading>
				<p>
					We model gracious professionalism within and around our local community,
					serving FIRST's mission of giving participants skills, confidence, and
					resilience to build a better world.
				</p>
			</Card>
			<Card>
				<Eyebrow>Engineering goals</Eyebrow>
				<SectionHeading size="card">Build with standards.</SectionHeading>
				<p>
					Driven by a desire to implement industry standards, develop team skills,
					and share memories with our community, we work together to build the best
					robot we can.
				</p>
			</Card>
		</Grid>
	</BandSection>
</BaseLayout>
