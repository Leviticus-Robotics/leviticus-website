---
import { sponsors } from "../data/team";
import Actions from "../components/ui/Actions.astro";
import ButtonLink from "../components/ui/ButtonLink.astro";
import Card from "../components/ui/Card.astro";
import DisplayHeading from "../components/ui/DisplayHeading.astro";
import Eyebrow from "../components/ui/Eyebrow.astro";
import Grid from "../components/ui/Grid.astro";
import Lead from "../components/ui/Lead.astro";
import PageShell from "../components/ui/PageShell.astro";
import SectionHeader from "../components/ui/SectionHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
	title="Sponsors"
	description="See FTC team 36099 Leviticus sponsors and learn how to apply as a sponsor."
>
	<section aria-labelledby="sponsors-title">
		<PageShell>
			<SectionHeader>
				<DisplayHeading id="sponsors-title">Sponsors</DisplayHeading>
				<Lead>
					Our mission wouldn't be possible without the generous support of our sponsors.
				</Lead>
				<Actions>
					<ButtonLink href="https://docs.google.com/forms/d/e/1FAIpQLSeuJUMxnH5lCd4_8uXCmLIfoTVo3fTaCCV93saXGdi8oOH6Yg/viewform?usp=publish-editor" target="_blank" rel="noreferrer">
						Sponsor us!
					</ButtonLink>
				</Actions>
			</SectionHeader>
			{
				sponsors.length > 0 ? (
					<Grid>
						{
					sponsors.map((sponsor) => (
						<Card as="article">
							<div
								class="mb-4 grid min-h-32 w-full place-items-center rounded-md bg-site-surface-strong bg-linear-to-br from-brand-purple/18 to-brand-blue/20 text-3xl font-black text-brand-purple-strong"
								aria-hidden="true"
							>
								{sponsor.name
									.split(" ")
									.map((part) => part[0])
									.slice(0, 3)
									.join("")}
							</div>
							<Eyebrow>{sponsor.level}</Eyebrow>
							<h2 class="text-2xl">{sponsor.name}</h2>
							<a class="font-extrabold text-brand-blue-strong underline-offset-[0.2em]" href={sponsor.url}>
								Visit {sponsor.name}
							</a>
						</Card>
					))
						}
					</Grid>
				) : (
					<Card>
						<h2 class="mb-3 text-2xl">Become an inaugural sponsor</h2>
						<p>
							We are building our first sponsor roster. Organizations can use the application
							above to start a conversation with the team.
						</p>
					</Card>
				)
			}
		</PageShell>
	</section>
</BaseLayout>
