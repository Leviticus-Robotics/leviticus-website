---
import Actions from "../components/ui/Actions.astro";
import BandSection from "../components/ui/BandSection.astro";
import ButtonLink from "../components/ui/ButtonLink.astro";
import DisplayHeading from "../components/ui/DisplayHeading.astro";
import Eyebrow from "../components/ui/Eyebrow.astro";
import FeatureCard from "../components/ui/FeatureCard.astro";
import Grid from "../components/ui/Grid.astro";
import HeroSection from "../components/ui/HeroSection.astro";
import Lead from "../components/ui/Lead.astro";
import PhotoLightbox from "../components/PhotoLightbox.svelte";
import SectionHeader from "../components/ui/SectionHeader.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import { robotPhotos } from "../data/robotPhotos";
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../utils/paths";
---

<BaseLayout
	title="Home"
	description="FTC team 36099 Leviticus builds robots, skills, and community through student-led engineering."
>
	<HeroSection aria-labelledby="home-title">
		<div>
			<Eyebrow>FTC Team 36099</Eyebrow>
			<DisplayHeading id="home-title">Leviticus</DisplayHeading>
			<Lead>
				A student-led robotics team building competitive machines, practical engineering
				skills, and a stronger STEM community.
			</Lead>
			<Actions>
				<ButtonLink href="/meet-our-team/">Meet the team</ButtonLink>
				<ButtonLink href="/sponsors/" variant="secondary">Support Leviticus</ButtonLink>
			</Actions>
		</div>
		<figure
			class="m-0 overflow-hidden rounded-lg border border-site-line bg-site-ink shadow-[0_20px_55px_color-mix(in_srgb,var(--color-brand-purple-strong)_15%,transparent)]"
		>
			<img
				class="aspect-4/3 w-full object-cover object-[58%_50%]"
				src={withBase("/previous_robot.png")}
				alt="Previous FTC robot render"
				width="2224"
				height="1492"
			/>
		</figure>
	</HeroSection>

	<BandSection aria-labelledby="robot-gallery-title" class="py-14">
		<PhotoLightbox label="Robot detail" client:load>
			<div data-robot-carousel>
				<div class="mb-8 flex items-end justify-between gap-6 max-[640px]:items-start">
					<SectionHeader class="mb-0">
						<Eyebrow>Robot photos</Eyebrow>
						<SectionHeading id="robot-gallery-title">Build gallery</SectionHeading>
						<Lead>The robot components we've designed.</Lead>
					</SectionHeader>
					<div class="flex shrink-0 gap-2" aria-label="Robot gallery controls">
						<button
							class="inline-grid size-11 place-items-center rounded-full border border-brand-blue/20 bg-white text-brand-blue shadow-sm transition hover:border-brand-blue/40 hover:bg-brand-blue hover:text-white focus:outline-2 focus:outline-offset-2 focus:outline-brand-blue"
							type="button"
							aria-label="Previous robot photo"
							data-robot-carousel-prev
						>
							<svg
								class="size-5"
								aria-hidden="true"
								focusable="false"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<path d="m15 18-6-6 6-6"></path>
							</svg>
						</button>
						<button
							class="inline-grid size-11 place-items-center rounded-full border border-brand-blue/20 bg-white text-brand-blue shadow-sm transition hover:border-brand-blue/40 hover:bg-brand-blue hover:text-white focus:outline-2 focus:outline-offset-2 focus:outline-brand-blue"
							type="button"
							aria-label="Next robot photo"
							data-robot-carousel-next
						>
							<svg
								class="size-5"
								aria-hidden="true"
								focusable="false"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<path d="m9 18 6-6-6-6"></path>
							</svg>
						</button>
					</div>
				</div>

				<div
					class="flex snap-x snap-mandatory gap-4 overflow-x-auto scroll-smooth pb-4"
					data-robot-carousel-viewport
				>
					{
						robotPhotos.map((photo, index) => (
							<figure class="m-0 min-w-[calc((100%-4rem)/5)] snap-start overflow-hidden rounded-md border border-brand-blue/15 bg-white shadow-sm max-[980px]:min-w-[calc((100%-2rem)/3)] max-[640px]:min-w-[78vw]">
								<button
									class="block h-full w-full cursor-zoom-in bg-white text-left transition hover:bg-site-blue-soft focus:outline-2 focus:outline-offset-[-6px] focus:outline-brand-blue"
									type="button"
									aria-label={`View details for ${photo.alt}`}
									data-lightbox-image={withBase(photo.image)}
									data-lightbox-alt={photo.alt}
									data-lightbox-long-description={photo.longDescription}
									data-lightbox-label="Robot detail"
								>
									<img
										class="aspect-4/3 h-full w-full object-contain p-2"
										src={withBase(photo.image)}
										alt={photo.alt}
										loading={index === 0 ? "eager" : "lazy"}
									/>
								</button>
							</figure>
						))
					}
				</div>
			</div>
		</PhotoLightbox>
	</BandSection>

	<script>
		const carousel = document.querySelector("[data-robot-carousel-viewport]");
		const previousButton = document.querySelector("[data-robot-carousel-prev]");
		const nextButton = document.querySelector("[data-robot-carousel-next]");

		const scrollCarousel = (direction) => {
			if (!(carousel instanceof HTMLElement)) {
				return;
			}

			carousel.scrollBy({
				left: direction * carousel.clientWidth * 0.86,
				behavior: "smooth",
			});
		};

		previousButton?.addEventListener("click", () => scrollCarousel(-1));
		nextButton?.addEventListener("click", () => scrollCarousel(1));
	</script>

	<BandSection aria-labelledby="snapshot-title">
		<SectionHeader>
			<SectionHeading id="snapshot-title">Explore</SectionHeading>
		</SectionHeader>
		<Grid>
			<FeatureCard href="/meet-our-team/">
				<h3 class="text-xl leading-tight">Meet Our Team</h3>
				<p>
					Meet students from FTC 7854 and 15385, teams with World Championship and
					Premiere Events experience.
				</p>
			</FeatureCard>
			<FeatureCard href="/mission-statement/">
				<h3 class="text-xl leading-tight">Mission Statement</h3>
				<p>Why Leviticus exists and the goals guiding the team.</p>
			</FeatureCard>
			<FeatureCard href="/contact/">
				<h3 class="text-xl leading-tight">Contact</h3>
				<p>Email, phone, and social links for families, sponsors, and community partners.</p>
			</FeatureCard>
		</Grid>
	</BandSection>
</BaseLayout>
