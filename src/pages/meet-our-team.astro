---
import { teamMembers } from "../data/team";
import DisplayHeading from "../components/ui/DisplayHeading.astro";
import Eyebrow from "../components/ui/Eyebrow.astro";
import Grid from "../components/ui/Grid.astro";
import Lead from "../components/ui/Lead.astro";
import PageShell from "../components/ui/PageShell.astro";
import SectionHeader from "../components/ui/SectionHeader.astro";
import TeamMemberCard from "../components/TeamMemberCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
	title="Meet Our Team"
	description="Meet the FTC 36099 Leviticus students, their roles, and experience."
>
	<section aria-labelledby="team-title">
		<PageShell>
			<SectionHeader>
				<Eyebrow>Meet Our Team</Eyebrow>
				<DisplayHeading id="team-title">Students behind the robot.</DisplayHeading>
				<Lead>
					Leviticus brings together students from FTC teams 7854 and 15385, programs
					with experience competing at the World Championship and Premiere Events.
					That background shapes how we build, practice, and help new teammates grow.
				</Lead>
			</SectionHeader>
			<Grid class="items-stretch">
				{
					teamMembers.map((member) => <TeamMemberCard member={member} />)
				}
			</Grid>
		</PageShell>
	</section>
</BaseLayout>
