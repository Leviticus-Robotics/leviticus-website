---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import type { TeamMember } from "../types/content";
import Card from "./ui/Card.astro";

interface Props {
	member: TeamMember;
}

const { member } = Astro.props;
const initials = member.name
	.split(" ")
	.map((part) => part[0])
	.join("");
const memberImages = import.meta.glob<{ default: ImageMetadata }>(
	"/src/assets/members/*.{jpeg,jpg,png,gif}",
);

if (member.photo && !memberImages[member.photo]) {
	throw new Error(
		`"${member.photo}" does not exist in glob: "src/assets/members/*.{jpeg,jpg,png,gif}"`,
	);
}

const photo = member.photo ? (await memberImages[member.photo]()).default : undefined;
const photoWidths = photo
	? [...new Set([Math.min(360, photo.width), Math.min(720, photo.width)])]
	: [];
---

<Card as="article">
	{
		photo ? (
			<Image
				class="mb-4 aspect-4/3 w-full rounded-md object-cover object-(--member-photo-crop)"
				src={photo}
				alt={`${member.name}, ${member.role}`}
				style={`--member-photo-crop: ${member.photoCrop};`}
				format="avif"
				widths={photoWidths}
				sizes="(max-width: 760px) calc(100vw - 2rem), 360px"
				loading="lazy"
			/>
		) : (
			<div
				class="mb-4 grid aspect-4/3 w-full place-items-center rounded-md bg-linear-to-br from-brand-purple to-brand-blue text-3xl font-black text-white"
				aria-hidden="true"
			>
				{initials}
			</div>
		)
	}
	<p class="mb-1 font-extrabold text-brand-blue">{member.role}</p>
	<h2 class="mb-3 text-2xl">{member.name}</h2>
	<p>{member.bio}</p>
	<h3 class="mt-5 mb-2 text-[0.95rem]">Prior experience</h3>
	<ul class="mt-4 flex list-none flex-wrap gap-2 p-0">
		{
			member.experiences.map((experience) => (
				<li class="rounded-full bg-site-blue-soft px-3 py-1.5 text-[0.85rem] font-bold text-brand-blue-strong">
					{experience}
				</li>
			))
		}
	</ul>
</Card>
