---
interface Props {
	href: string;
	class?: string;
}

const { href, class: className } = Astro.props;
---

<a
	class:list={[
		"rounded-lg border border-site-line bg-white/85 p-5 text-inherit no-underline shadow-[0_10px_30px_color-mix(in_srgb,var(--color-brand-blue)_8%,transparent)] transition hover:-translate-y-0.5 hover:border-brand-purple",
		className,
	]}
	href={href}
>
	<slot />
</a>
