---
interface Props {
	as?: "div" | "article" | "section";
	class?: string;
}

const { as = "div", class: className } = Astro.props as Props;
const Tag = as;
---

<Tag
	class:list={[
		"rounded-lg border border-site-line bg-white/85 p-5 shadow-[0_10px_30px_color-mix(in_srgb,var(--color-brand-blue)_8%,transparent)]",
		className,
	]}
>
	<slot />
</Tag>
