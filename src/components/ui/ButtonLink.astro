---
import { withBase } from "../../utils/paths";

interface Props {
	href: string;
	variant?: "primary" | "secondary";
	target?: string;
	rel?: string;
	class?: string;
}

const { href, variant = "primary", target, rel, class: className } = Astro.props;
---

<a
	class:list={[
		"inline-flex min-h-[2.9rem] items-center justify-center rounded-full px-4 py-3 font-extrabold no-underline",
		variant === "primary" &&
			"bg-brand-purple text-white shadow-[0_12px_28px_color-mix(in_srgb,var(--color-brand-purple)_22%,transparent)]",
		variant === "secondary" && "border border-site-line bg-white text-brand-purple-strong",
		className,
	]}
	href={withBase(href)}
	target={target}
	rel={rel}
>
	<slot />
</a>
