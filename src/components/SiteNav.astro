---
import { Image } from "astro:assets";
import logo from "../assets/logo.png";
import type { NavLink } from "../types/content";
import { withBase } from "../utils/paths";

interface Props {
	currentPath: string;
}

const { currentPath } = Astro.props;

const links: NavLink[] = [
	{ href: "/meet-our-team/", label: "Meet Our Team" },
	{ href: "/mission-statement/", label: "Mission Statement" },
	{ href: "/contact/", label: "Contact" },
	{ href: "/sponsors/", label: "Sponsors" },
];

const isCurrentPage = (href: string) => currentPath === href || currentPath === withBase(href);
---

<header
	class="sticky top-0 z-10 flex items-center justify-between gap-6 border-b border-site-line/85 bg-white/85 px-4 py-3 backdrop-blur-[18px] min-[1184px]:px-[calc((100vw-1120px)/2)] max-[720px]:flex-col max-[720px]:items-start"
>
	<a
		class="inline-flex min-w-max items-center gap-3 text-site-ink-soft no-underline"
		href={withBase("/")}
		aria-label="FTC 36099 Leviticus home"
	>
		<Image
			class="h-14 w-auto"
			src={logo}
			alt="Leviticus 36099 logo"
			format="avif"
			widths={[84, 168]}
			sizes="84px"
			loading="eager"
		/>
	</a>
	<nav aria-label="Main navigation">
		<ul class="m-0 flex list-none flex-wrap justify-end gap-2 p-0 max-[720px]:justify-start">
			{
				links.map((link) => (
					<li>
						<a
							class:list={[
								"inline-flex min-h-9 items-center rounded-full px-3 py-2 text-[0.95rem] font-extrabold text-site-nav no-underline hover:bg-site-blue-soft hover:text-brand-purple-strong",
								isCurrentPage(link.href) && "bg-site-blue-soft text-brand-purple-strong",
							]}
							href={withBase(link.href)}
							aria-current={isCurrentPage(link.href) ? "page" : undefined}
						>
							{link.label}
						</a>
					</li>
				))
			}
		</ul>
	</nav>
</header>
