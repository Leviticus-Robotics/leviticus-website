---
import { getImage, Image } from "astro:assets";
import hcbIcon from "../assets/icons/hcb.png";
import instagramIcon from "../assets/icons/instagram.png";
import logo from "../assets/logo.png";
import SiteNav from "../components/SiteNav.astro";
import { contactLinks, siteLinks } from "../data/site";
import "../styles/global.css";

interface Props {
	title: string;
	description: string;
}

const { title, description } = Astro.props;
const favicon = await getImage({ src: logo, width: 64, format: "png" });
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href={favicon.src} />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | FTC 36099 Leviticus</title>
	</head>
	<body
		class="bg-[radial-gradient(circle_at_top_left,color-mix(in_srgb,var(--color-brand-purple)_16%,transparent),transparent_34rem),linear-gradient(135deg,var(--color-site-surface-soft)_0%,var(--color-site-surface-blue)_100%)] text-site-ink leading-[1.6]"
	>
		<a
			class="fixed top-4 left-4 z-20 -translate-y-[150%] rounded-full bg-site-ink px-4 py-3 text-white no-underline transition-transform duration-150 focus:translate-y-0"
			href="#main">Skip to main content</a
		>
		<SiteNav currentPath={Astro.url.pathname} />
		<main id="main" class="min-h-[70vh]">
			<slot />
		</main>
		<footer class="bg-site-ink text-white">
			<div
				class="mx-auto grid max-w-7xl grid-cols-[1fr_1fr_1fr] gap-10 px-4 py-12 max-[840px]:grid-cols-1"
			>
				<section aria-labelledby="footer-team">
					<h2 id="footer-team" class="mb-3 text-xl font-extrabold">FTC Team 36099 Leviticus</h2>
					<p class="text-white/65">© 2026 Leviticus Robotics. All rights reserved.</p>
				</section>

				<section aria-labelledby="footer-contact">
					<h2 id="footer-contact" class="mb-3 text-xl font-extrabold">Contact</h2>
					<ul class="m-0 list-none space-y-3 p-0">
						{
							contactLinks.map((contact) => (
								<li>
									<a
										class="font-extrabold text-white/85 underline-offset-[0.2em] hover:text-white"
										href={contact.href}
									>
										{contact.value}
									</a>
								</li>
							))
						}
					</ul>
				</section>

				<section aria-labelledby="footer-links">
					<h2 id="footer-links" class="mb-3 text-xl font-extrabold">Links</h2>
					<ul class="m-0 flex list-none flex-wrap gap-3 p-0">
						<li>
							<a
								class="inline-grid size-11 place-items-center rounded-full border border-white/20 text-white/85 transition hover:border-white/45 hover:text-white"
								href={siteLinks.email}
								aria-label="Email Leviticus Robotics"
							>
								<svg
									class="size-5"
									aria-hidden="true"
									focusable="false"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
								>
									<rect width="20" height="16" x="2" y="4" rx="2"></rect>
									<path d="m22 7-8.97 5.7a2 2 0 0 1-2.06 0L2 7"></path>
								</svg>
							</a>
						</li>
						<li>
							<a
								class="inline-grid size-11 place-items-center rounded-full border border-white/20 text-white/85 transition hover:border-white/45 hover:text-white"
								href={siteLinks.github}
								aria-label="Leviticus Robotics on GitHub"
							>
								<svg
									class="size-5"
									aria-hidden="true"
									focusable="false"
									viewBox="0 0 24 24"
									fill="currentColor"
								>
									<path
										fill-rule="evenodd"
										clip-rule="evenodd"
										d="M12 2C6.48 2 2 6.58 2 12.22c0 4.52 2.87 8.35 6.84 9.7.5.09.68-.22.68-.49 0-.24-.01-1.04-.01-1.89-2.51.47-3.16-.62-3.36-1.19-.11-.29-.6-1.19-1.02-1.43-.35-.19-.85-.66-.01-.67.79-.01 1.35.74 1.54 1.05.9 1.55 2.34 1.11 2.91.85.09-.67.35-1.11.64-1.37-2.22-.26-4.55-1.14-4.55-5.05 0-1.11.39-2.03 1.02-2.74-.1-.26-.45-1.3.1-2.7 0 0 .84-.28 2.75 1.05A9.31 9.31 0 0 1 12 6.99c.85 0 1.7.12 2.5.35 1.91-1.33 2.75-1.05 2.75-1.05.55 1.4.2 2.44.1 2.7.64.71 1.02 1.62 1.02 2.74 0 3.92-2.34 4.79-4.57 5.05.36.32.68.93.68 1.89 0 1.37-.01 2.47-.01 2.81 0 .27.18.59.69.49A10.06 10.06 0 0 0 22 12.22C22 6.58 17.52 2 12 2Z"
									></path>
								</svg>
							</a>
						</li>
						<li>
							<a
								class="group inline-grid size-11 place-items-center rounded-full border border-white/20 text-white/85 transition hover:border-white/45 hover:text-white"
								href={siteLinks.hcb}
								aria-label="Leviticus Robotics on HCB"
							>
								<Image
									class="size-6 brightness-125 opacity-85 transition group-hover:opacity-100"
									src={hcbIcon}
									alt=""
									aria-hidden="true"
									width={48}
									format="webp"
									loading="lazy"
								/>
							</a>
						</li>
						<li>
							<a
								class="group inline-grid size-11 place-items-center rounded-full border border-white/20 text-white/85 transition hover:border-white/45 hover:text-white"
								href={siteLinks.instagram}
								aria-label="Leviticus Robotics on Instagram"
							>
								<Image
									class="size-6 brightness-125 opacity-85 transition group-hover:opacity-100"
									src={instagramIcon}
									alt=""
									aria-hidden="true"
									width={48}
									format="webp"
									loading="lazy"
								/>
							</a>
						</li>
					</ul>
				</section>
			</div>
		</footer>
	</body>
</html>
